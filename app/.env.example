# Copiar a .env.local y completar. .env.local NUNCA se commitea.

# Supabase (Settings → API del proyecto)
NEXT_PUBLIC_SUPABASE_URL=https://XXXX.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# SOLO servidor (API routes / workers) — jamás NEXT_PUBLIC_
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Chat Claude embebido. Solo servidor (NUNCA NEXT_PUBLIC_).
# Sin ANTHROPIC_API_KEY, el chat corre en "modo demo" sobre datos mock.
ANTHROPIC_API_KEY=sk-ant-...
# Modelo del chat (opcional). Por defecto claude-opus-4-8.
ANTHROPIC_MODEL=claude-opus-4-8

# Integraciones (cuando se activen)
SHOPIFY_WEBHOOK_SECRET=
SIIGO_USERNAME=
SIIGO_ACCESS_KEY=
